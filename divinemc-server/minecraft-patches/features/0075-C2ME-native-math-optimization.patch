From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: NONPLAYT <nonplay@bxteam.org>
Date: Wed, 20 May 2026 01:01:37 +0300
Subject: [PATCH] C2ME: native math optimization

This patch is based on the c2me-opts-natives-math module
By: ishland <ishlandmc@yeah.net>
As part of: C2ME (https://github.com/RelativityMC/C2ME-fabric)
Licensed under: MIT (https://opensource.org/licenses/MIT)

diff --git a/net/minecraft/server/Main.java b/net/minecraft/server/Main.java
index 3d5b7fd67d203b09cb68a14b062d24d11daab19f..27be72cc6d015d51aa588cf3b5e0e96dbf3cf674 100644
--- a/net/minecraft/server/Main.java
+++ b/net/minecraft/server/Main.java
@@ -106,6 +106,18 @@ public class Main {
             org.purpurmc.purpur.PurpurConfig.registerMinecraftDisabledCommands = purpurConfiguration.getBoolean("settings.register-minecraft-disabled-commands"); // Purpur - register disabled minecraft commands
             // Purpur end - Add toggle for enchant level clamping - load config files early
 
+            // DivineMC start - C2ME: native math optimization
+            org.bukkit.configuration.file.YamlConfiguration divinemcConfiguration = io.papermc.paper.configuration.PaperConfigurations.loadLegacyConfigFile((File) options.valueOf("divinemc-settings"));
+            boolean divinemcNativeMathEnabled = divinemcConfiguration.getBoolean("performance.chunks.native-acceleration.enabled", true);
+            if (divinemcNativeMathEnabled) {
+                try {
+                    Class.forName("org.bxteam.divinemc.math.NativeLoader").getField("lookup").get(null);
+                } catch (Throwable e) {
+                    e.printStackTrace();
+                }
+            }
+            // DivineMC end - C2ME: native math optimization
+
             io.papermc.paper.plugin.PluginInitializerManager.load(options); // Paper
             Bootstrap.bootStrap();
             Bootstrap.validate();
