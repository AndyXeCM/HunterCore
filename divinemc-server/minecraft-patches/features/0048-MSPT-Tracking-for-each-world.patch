Date: Sat, 1 Feb 2025 18:55:59 +0300
Subject: [PATCH] MSPT Tracking for each world


diff --git a/net/minecraft/server/MinecraftServer.java b/net/minecraft/server/MinecraftServer.java
index cb8068dff87f406d05548e9394857b6bf4d4c0df..ce26c8cd35c39ccf66e1b4d6fded520fab745c03 100644
--- a/net/minecraft/server/MinecraftServer.java
+++ b/net/minecraft/server/MinecraftServer.java
@@ -1860,7 +1860,16 @@ public abstract class MinecraftServer extends ReentrantBlockableEventLoop<TickTa
     // DivineMC start - Parallel world ticking
     private void tickLevel(ServerLevel serverLevel, BooleanSupplier haveTime) {
         try {
+            // DivineMC start - MSPT Tracking for each world
+            long tickStart = Util.getNanos();
             serverLevel.tick(haveTime);
+
+            long tickDuration = Util.getNanos() - tickStart;
+
+            serverLevel.tickTimes5s.add(this.tickCount, tickDuration);
+            serverLevel.tickTimes10s.add(this.tickCount, tickDuration);
+            serverLevel.tickTimes60s.add(this.tickCount, tickDuration);
+            // DivineMC end - MSPT Tracking for each world
         } catch (Throwable levelTickingException) {
             CrashReport crashReport = CrashReport.forThrowable(levelTickingException, "Exception ticking world");
             serverLevel.fillReportDetails(crashReport);
diff --git a/net/minecraft/server/level/ServerLevel.java b/net/minecraft/server/level/ServerLevel.java
index 415b9e2016547e81ae82fcbe7d92e39910e5b2aa..e591ba2d21c3f8dcad10b12aad1613a30c3ce928 100644
--- a/net/minecraft/server/level/ServerLevel.java
+++ b/net/minecraft/server/level/ServerLevel.java
@@ -610,6 +610,12 @@ public class ServerLevel extends Level implements WorldGenLevel, ServerEntityGet
     }
     // Paper end - chunk tick iteration
 
+    // DivineMC start - MSPT Tracking for each world
+    public final MinecraftServer.TickTimes tickTimes5s = new MinecraftServer.TickTimes(100);
+    public final MinecraftServer.TickTimes tickTimes10s = new MinecraftServer.TickTimes(200);
+    public final MinecraftServer.TickTimes tickTimes60s = new MinecraftServer.TickTimes(1200);
+    // DivineMC end - MSPT Tracking for each world
+
     public ServerLevel(
         final MinecraftServer server,
         final Executor executor,
